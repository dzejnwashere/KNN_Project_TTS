{"audio_filepath": "/home/dzejn/Documents/all-datasets/OAF_void_sad.wav", "emotion": "sad", "duration": 2.5724, "text": "Say the word void."}
{"audio_filepath": "/home/dzejn/Documents/all-datasets/amused_137-140_0137_jenie.wav", "emotion": "amused", "duration": 4.3276, "text": "Then he stepped back with a low cry of pleasure."}
{"audio_filepath": "/home/dzejn/Documents/all-datasets/YAF_ripe_neutral.wav", "emotion": "neutral", "duration": 1.8981, "text": "Say the word ripe."}
{"audio_filepath": "/home/dzejn/Documents/all-datasets/YAF_whip_happy.wav", "emotion": "happy", "duration": 1.9274, "text": "Say the word whip."}
{"audio_filepath": "/home/dzejn/Documents/all-datasets/amused_252-280_0267_josh.wav", "emotion": "amused", "duration": 4.5608, "text": "Eli Harding asked, as Chunk started to follow."}
