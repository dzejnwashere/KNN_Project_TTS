{"audio_filepath": "/home/dzejn/Documents/all-datasets/amused_169-196_0175_bea.wav", "emotion": "amused", "duration": 4.1617, "text": "Down there the earth was already swelling with life."}
{"audio_filepath": "/home/dzejn/Documents/all-datasets/neutral_141-168_0150_bea.wav", "emotion": "neutral", "duration": 2.978, "text": "Goodbye, Pierre, he shouted."}
{"audio_filepath": "/home/dzejn/Documents/all-datasets/amused_95-112_0112_jenie.wav", "emotion": "amused", "duration": 4.3664, "text": "He was wounded in the arm."}
